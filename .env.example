# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

S3_RAW_BUCKET=nih-trials-raw
S3_BRONZE_BUCKET=nih-trials-bronze
S3_SILVER_BUCKET=nih-trials-silver
S3_GOLD_BUCKET=nih-trials-gold

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Redshift ──────────────────────────────────────────────────────────────────
REDSHIFT_HOST=your-cluster.xxxx.us-east-1.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=nih_trials
REDSHIFT_USER=admin
REDSHIFT_PASSWORD=your_password_here

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
